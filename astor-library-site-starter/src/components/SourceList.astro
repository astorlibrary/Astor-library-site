---
const { sources = [] } = Astro.props;
---

{sources.length > 0 && (
  <section class="panel source-panel">
    <p class="eyebrow">Sources used for this page</p>
    <ul class="source-list">
      {sources.map((source) => (
        <li>
          <a href={source.url}>{source.label}</a>
          {source.note && <span>{source.note}</span>}
        </li>
      ))}
    </ul>
  </section>
)}
