---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookCard from '../../components/BookCard.astro';
import { books } from '../../data/books';

const plays = books.filter((book) => book.author === 'William Shakespeare');
---

<BaseLayout title="Shakespeare" description="Astor Shakespeare pages with Folger-style depth, study support and performance context.">
  <section class="page-hero">
    <p class="eyebrow">Shakespeare</p>
    <h1>Play pages shaped by context, performance, scenes and study use.</h1>
    <p class="lead">The model is a proper hub for each play: overview, characters, scenes, key passages, criticism, adaptations and edition links.</p>
  </section>

  <section class="section split-feature">
    <div>
      <p class="eyebrow">Page structure</p>
      <h2>Each play should feel like a resource first.</h2>
      <p>Folger is the depth reference: play hubs, reading support, character lists and scene navigation. Astor should adapt that depth into a cleaner study-focused structure.</p>
    </div>
    <div class="panel">
      <ul class="feature-list">
        <li>Play overview</li>
        <li>Characters</li>
        <li>Act and scene guide</li>
        <li>Key passages</li>
        <li>Context and criticism</li>
        <li>Performance and adaptation</li>
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="book-grid">
      {plays.map((book) => <BookCard book={book} />)}
    </div>
  </section>
</BaseLayout>
