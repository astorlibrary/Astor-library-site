---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Study Resources" description="English and Media study resources linked to Astor Library editions.">
  <section class="page-hero">
    <p class="eyebrow">Study resources</p>
    <h1>Resources connected to the books, not hidden on a separate island.</h1>
    <p class="lead">This section can hold GCSE English, A Level English, Media Studies, Shakespeare packs, set-text guides and downloadable materials.</p>
  </section>

  <section class="section period-grid">
    <a class="period-card" href="#">
      <h3>GCSE English Literature</h3>
      <p>Set-text guides, quotations, essay planning and exam-board focused support.</p>
    </a>
    <a class="period-card" href="#">
      <h3>A Level English Literature</h3>
      <p>Context, criticism, interpretations and comparative study support.</p>
    </a>
    <a class="period-card" href="#">
      <h3>Media Studies</h3>
      <p>Exam board pages, CSP guides and structured revision material.</p>
    </a>
    <a class="period-card" href="#">
      <h3>Teacher resources</h3>
      <p>Classroom-ready material and resources linked to Astor editions.</p>
    </a>
  </section>
</BaseLayout>
