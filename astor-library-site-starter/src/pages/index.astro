---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookCard from '../components/BookCard.astro';
import { books, periods } from '../data/books';

const featured = books.slice(0, 4);
---

<BaseLayout
  title="Astor Library"
  description="Readable classic literature editions and study resources for English and Media."
>
  <section class="hero hero-rich">
    <div class="hero-copy">
      <p class="eyebrow">Classic texts, properly introduced</p>
      <h1>Readable editions. Serious study support. Pages built around the things students are rarely told.</h1>
      <p class="lead">Astor Library brings classic literature together with context, adaptations, performance history and study material. The books sell through familiar platforms, but the site is designed as a useful resource in its own right.</p>
      <div class="button-row">
        <a class="button primary" href="/library/">Explore the library</a>
        <a class="button secondary" href="/study/">Study resources</a>
      </div>
    </div>
    <div class="hero-stack" aria-label="Featured Astor editions">
      {featured.map((book, index) => (
        <a href={`/books/${book.slug}/`} class={`stack-book stack-${index + 1}`} style={`--accent:${book.accent};`}>
          <span>ASTOR LIBRARY</span>
          <strong>{book.title}</strong>
          <em>{book.author}</em>
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Featured editions</p>
      <h2>Product pages that work as study pages</h2>
      <p>Each page should open with researched context, then move through study support, adaptations, sources and buying links.</p>
    </div>
    <div class="book-grid">
      {featured.map((book) => <BookCard book={book} />)}
    </div>
  </section>

  <section class="section split-feature">
    <div>
      <p class="eyebrow">Example page direction</p>
      <h2>Macbeth should not open with generic ambition notes.</h2>
      <p>The stronger page begins with the historical Macbeth, the First Folio text, James I, succession anxiety, Middleton questions and performance history. Product placement comes after the page has become useful.</p>
      <a class="text-link" href="/books/macbeth/">View sample Macbeth page</a>
    </div>
    <div class="quote-card">
      <p>“The Macbeth most students meet is not simply Scottish history placed on stage. It is Shakespeare making history faster, stranger and more theatrically useful.”</p>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Explore by period</p>
      <h2>A catalogue built for browsing and search</h2>
    </div>
    <div class="period-grid">
      {periods.map((period) => (
        <a class="period-card" href={`/periods/${period.slug}/`}>
          <h3>{period.title}</h3>
          <p>{period.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
